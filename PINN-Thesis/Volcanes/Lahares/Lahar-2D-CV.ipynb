    "# ============================================================\n",
    "# SELECCIÓN DE TOPOGRAFÍA\n",
    "# ============================================================\n",
    "TOPO_SCENARIO = 1 # 1: plano inclinado, 2: valle gaussiano, 3: canal sinuoso\n",
    "# ============================================================\n",
    "# 1) PARÁMETROS FÍSICOS\n",
    "# ============================================================\n",
    "g = 9.81\n",
    "rho_m = 1800.0\n",
    "mu0 = 0.20\n",
    "alpha_C = 1.2\n",
    "alpha_p = 4.0\n",
    "C0 = 0.45\n",
    "p_ref = 1e4\n",
    "kappa_C = 5.0\n",
    "tau_C = 1e9 # relajación casi nula para C\n",
    "tau_p = 120.0\n",
    "chi_p = 0.35\n",
    "u_star = 1.0\n",
    "C_star = 0.05\n",
    "eps_u = 1e-3\n",
    "eps_h = 1e-6\n",
    "# ============================================================\n",
    "# 2) DOMINIO\n",
    "# ============================================================\n",
    "Lx = 10_000.0\n",
    "Ly = 2_000.0\n",
    "Tmax = 1_200.0\n",
    "x_min, x_max = 0.0, Lx\n",
    "y_min, y_max = -Ly/2, Ly/2\n",
    "t_min, t_max = 0.0, Tmax\n",
    "# Normalización\n",
    "x_scale = Lx\n",
    "y_scale = Ly/2\n",
    "t_scale = Tmax\n",
    "h_scale = 10.0\n",
    "u_scale = 10.0\n",
    "p_scale = rho_m * g * h_scale"
   ]
